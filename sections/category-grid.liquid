<section class="bp-category">
  <div class="page-width">

    <div class="bp-section-heading">
      <span>SHOP BY CATEGORY</span>
      <h2>Find Your Style</h2>
      <p>Explore our premium collections.</p>
    </div>

    <div class="bp-category-grid">

      {% for block in section.blocks %}

      <a href="{{ block.settings.link }}"
         class="bp-category-card"
         {{ block.shopify_attributes }}>

        {% if block.settings.image != blank %}
          <img
            src="{{ block.settings.image | image_url: width: 900 }}"
            alt="{{ block.settings.title }}"
            loading="lazy"
            width="900"
            height="900">
        {% endif %}

        <div class="bp-category-content">
          <h3>{{ block.settings.title }}</h3>
          <span>Explore →</span>
        </div>

      </a>

      {% endfor %}

    </div>

  </div>
  <style>

    .bp-category{
      padding:90px 0;
      background:#ffffff;
    }

    .bp-section-heading{
      text-align:center;
      margin-bottom:60px;
    }

    .bp-section-heading span{
      color:#c8a96a;
      font-size:13px;
      letter-spacing:3px;
      text-transform:uppercase;
    }

    .bp-section-heading h2{
      font-size:48px;
      margin:18px 0;
      color:#111;
      font-weight:700;
    }

    .bp-section-heading p{
      color:#666;
      font-size:17px;
    }

    .bp-category-grid{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:25px;
    }

    .bp-category-card{
      position:relative;
      overflow:hidden;
      border-radius:20px;
      text-decoration:none;
      background:#f7f7f7;
      transition:.35s;
      min-height:380px;
    }

    .bp-category-card img{
      width:100%;
      height:100%;
      object-fit:cover;
      transition:.4s;
    }

    .bp-category-card:hover img{
      transform:scale(1.08);
    }

    .bp-category-content{
      position:absolute;
      left:25px;
      bottom:25px;
      color:#fff;
      z-index:2;
    }

    .bp-category-content h3{
      font-size:28px;
      margin-bottom:8px;
    }

    .bp-category-content span{
      font-size:14px;
      letter-spacing:1px;
    }
    .bp-category-card::after{
      content:"";
      position:absolute;
      inset:0;
      background:linear-gradient(
        to top,
        rgba(0,0,0,.65),
        rgba(0,0,0,.15),
        transparent
      );
    }

    @media screen and (max-width:990px){
      .bp-category-grid{
        grid-template-columns:repeat(2,1fr);
      }
    }

    @media screen and (max-width:749px){

      .bp-category{
        padding:60px 0;
      }

      .bp-section-heading h2{
        font-size:34px;
      }

      .bp-category-grid{
        grid-template-columns:1fr;
      }

      .bp-category-card{
        min-height:280px;
      }

    }

  </style>

</section>

{% schema %}
{
  "name": "BrandPoint Categories",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "category",
      "name": "Category",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Category Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Collection Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "BrandPoint Categories"
    }
  ]
}
{% endschema %}
