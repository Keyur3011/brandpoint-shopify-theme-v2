<section class="bp-hero">
  <div class="bp-hero__overlay"></div>

  {% if section.settings.hero_image != blank %}
    <img
      src="{{ section.settings.hero_image | image_url: width: 2400 }}"
      alt="{{ section.settings.heading }}"
      class="bp-hero__image"
      loading="eager"
      width="2400"
      height="1400">
  {% endif %}

  <div class="page-width">
    <div class="bp-hero__content">

      {% if section.settings.badge != blank %}
        <span class="bp-hero__badge">
          {{ section.settings.badge }}
        </span>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h1 class="bp-hero__title">
          {{ section.settings.heading }}
        </h1>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="bp-hero__text">
          {{ section.settings.text }}
        </div>
      {% endif %}

      <div class="bp-hero__buttons">

        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link }}"
             class="bp-btn bp-btn--white">
            {{ section.settings.button_label }}
          </a>
        {% endif %}

        {% if section.settings.button2_label != blank %}
          <a href="{{ section.settings.button2_link }}"
             class="bp-btn bp-btn--outline">
            {{ section.settings.button2_label }}
          </a>
        {% endif %}

      </div>
    </div>
  </div>

  <style>
    .bp-hero{
      position:relative;
      min-height:100vh;
      display:flex;
      align-items:center;
      overflow:hidden;
      background:#000;
    }

    .bp-hero__image{
      position:absolute;
      inset:0;
      width:100%;
      height:100%;
      object-fit:cover;
      z-index:1;
    }

    .bp-hero__overlay{
      position:absolute;
      inset:0;
      background:rgba(0,0,0,.55);
      z-index:2;
    }

    .bp-hero .page-width{
      position:relative;
      z-index:3;
      width:100%;
    }

    .bp-hero__content{
      max-width:640px;
      color:#fff;
      padding:80px 20px;
    }

    .bp-hero__badge{
      display:inline-block;
      padding:8px 16px;
      border:1px solid rgba(255,255,255,.25);
      border-radius:30px;
      font-size:12px;
      letter-spacing:2px;
      margin-bottom:20px;
      text-transform:uppercase;
    }

    .bp-hero__title{
      font-size:72px;
      line-height:1;
      font-weight:300;
      letter-spacing:3px;
      margin:0 0 20px;
      text-transform:uppercase;
    }

    .bp-hero__text{
      max-width:520px;
      font-size:18px;
      line-height:1.8;
      color:#ddd;
      margin-bottom:35px;
    }

    .bp-hero__buttons{
      display:flex;
      gap:16px;
      flex-wrap:wrap;
    }
    .bp-btn{
      display:inline-flex;
      align-items:center;
      justify-content:center;
      padding:16px 34px;
      border-radius:999px;
      text-decoration:none;
      font-weight:600;
      transition:.3s ease;
    }

    .bp-btn--white{
      background:#ffffff;
      color:#000000;
    }

    .bp-btn--white:hover{
      background:#d4af37;
      color:#000;
    }

    .bp-btn--outline{
      border:2px solid #ffffff;
      color:#ffffff;
      background:transparent;
    }

    .bp-btn--outline:hover{
      background:#ffffff;
      color:#000;
    }

    @media(max-width:768px){

      .bp-hero{
        min-height:85vh;
      }

      .bp-hero__title{
        font-size:42px;
      }

      .bp-hero__text{
        font-size:16px;
      }

      .bp-hero__buttons{
        flex-direction:column;
      }

      .bp-btn{
        width:100%;
      }

    }
  </style>
</section>

{% schema %}
{
  "name": "BrandPoint Hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero Image"
    },
    {
      "type": "text",
      "id": "badge",
      "label": "Badge",
      "default": "NEW COLLECTION"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Premium Fashion Collection"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Discover timeless fashion with BrandPoint.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Primary Button",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "button2_label",
      "label": "Secondary Button",
      "default": "Explore"
    },
    {
      "type": "url",
      "id": "button2_link",
      "label": "Secondary Button Link"
    }
  ],
  "presets": [
    {
      "name": "BrandPoint Hero"
    }
  ]
}
{% endschema %}
