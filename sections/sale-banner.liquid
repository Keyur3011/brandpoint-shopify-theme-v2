<section class="bp-sale-banner">
  <div class="page-width">

    <div class="bp-sale-content">

      <span class="bp-sale-tag">
        LIMITED OFFER
      </span>

      <h2>{{ section.settings.heading }}</h2>

      <p>{{ section.settings.text }}</p>

      <div class="bp-countdown">

        <div class="bp-time">
          <span id="bp-days">00</span>
          <small>Days</small>
        </div>

        <div class="bp-time">
          <span id="bp-hours">00</span>
          <small>Hours</small>
        </div>

        <div class="bp-time">
          <span id="bp-minutes">00</span>
          <small>Minutes</small>
        </div>

        <div class="bp-time">
          <span id="bp-seconds">00</span>
          <small>Seconds</small>
        </div>

      </div>

      <a href="{{ section.settings.button_link }}"
         class="bp-sale-btn">
         {{ section.settings.button_text }}
      </a>

    </div>

  </div>
  <style>

    .bp-sale-banner{
      padding:100px 0;
      background:#111;
      color:#fff;
      text-align:center;
    }

    .bp-sale-content{
      max-width:800px;
      margin:0 auto;
    }

    .bp-sale-tag{
      display:inline-block;
      padding:8px 18px;
      border:1px solid #c8a96a;
      color:#c8a96a;
      border-radius:30px;
      font-size:13px;
      letter-spacing:2px;
      margin-bottom:20px;
    }

    .bp-sale-content h2{
      font-size:54px;
      margin-bottom:20px;
    }

    .bp-sale-content p{
      font-size:18px;
      color:#d9d9d9;
      margin-bottom:40px;
    }

    .bp-countdown{
      display:flex;
      justify-content:center;
      gap:20px;
      margin-bottom:40px;
      flex-wrap:wrap;
    }

    .bp-time{
      width:90px;
      height:90px;
      border-radius:16px;
      background:#1c1c1c;
      display:flex;
      flex-direction:column;
      justify-content:center;
      align-items:center;
      border:1px solid rgba(255,255,255,.08);
    }

    .bp-time span{
      font-size:30px;
      font-weight:700;
      color:#c8a96a;
    }

    .bp-time small{
      margin-top:5px;
      font-size:12px;
      color:#bbb;
      text-transform:uppercase;
    }

    .bp-sale-btn{
      display:inline-block;
      padding:15px 36px;
      background:#c8a96a;

  <script>
    (function () {
      const endDate = new Date("2030-12-31T23:59:59").getTime();

      function updateCountdown() {
        const now = new Date().getTime();
        const distance = endDate - now;

        if (distance <= 0) return;

        document.getElementById("bp-days").textContent =
          Math.floor(distance / (1000 * 60 * 60 * 24));

        document.getElementById("bp-hours").textContent =
          Math.floor((distance % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));

        document.getElementById("bp-minutes").textContent =
          Math.floor((distance % (1000 * 60 * 60)) / (1000 * 60));

        document.getElementById("bp-seconds").textContent =
          Math.floor((distance % (1000 * 60)) / 1000);
      }

      updateCountdown();
      setInterval(updateCountdown, 1000);
    })();
  </script>

</section>

{% schema %}
{
  "name": "BrandPoint Sale Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Mega Sale Up To 50% Off"
    },
    {
      "type": "textarea",
      "id": "text",
      "label": "Description",
      "default": "Don't miss our limited-time premium collection offers."
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    }
  ],
  "presets": [
    {
      "name": "BrandPoint Sale Banner"
    }
  ]
}
{% endschema %}
