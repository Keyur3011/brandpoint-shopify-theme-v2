<section class="bp-instagram">
  <div class="page-width">

    <div class="bp-section-heading">
      <span>FOLLOW US</span>
      <h2>Instagram Gallery</h2>
      <p>See the latest looks from @brandpoint</p>
    </div>

    <div class="bp-instagram-grid">

      {% for block in section.blocks %}

        <a href="{{ block.settings.link }}"
           class="bp-instagram-item"
           target="_blank"
           {{ block.shopify_attributes }}>

          {% if block.settings.image != blank %}
            <img
              src="{{ block.settings.image | image_url: width: 800 }}"
              alt="Instagram"
              loading="lazy"
              width="800"
              height="800">
          {% endif %}

          <div class="bp-instagram-overlay">
            <span>View Post</span>
          </div>

        </a>

      {% endfor %}

    </div>

  </div>
    <style>

    .bp-instagram{
      padding:100px 0;
      background:#ffffff;
    }

    .bp-instagram-grid{
      display:grid;
      grid-template-columns:repeat(4,1fr);
      gap:20px;
    }

    .bp-instagram-item{
      position:relative;
      display:block;
      overflow:hidden;
      border-radius:18px;
      text-decoration:none;
    }

    .bp-instagram-item img{
      width:100%;
      aspect-ratio:1/1;
      object-fit:cover;
      display:block;
      transition:.4s ease;
    }

    .bp-instagram-overlay{
      position:absolute;
      inset:0;
      background:rgba(0,0,0,.55);
      display:flex;
      align-items:center;
      justify-content:center;
      opacity:0;
      transition:.3s ease;
    }

    .bp-instagram-overlay span{
      color:#fff;
      font-size:16px;
      font-weight:600;
      border:1px solid #fff;
      padding:12px 24px;
      border-radius:999px;
    }

    .bp-instagram-item:hover img{
      transform:scale(1.08);
    }

    .bp-instagram-item:hover .bp-instagram-overlay{
      opacity:1;
    }

    @media(max-width:990px){
      .bp-instagram-grid{
        grid-template-columns:repeat(2,1fr);
      }
    }

    @media(max-width:749px){

      .bp-instagram{
        padding:60px 0;
      }

      .bp-instagram-grid{
        grid-template-columns:1fr;
        gap:16px;
      }

    }

  </style>

{% schema %}
{
  "name": "BrandPoint Instagram Feed",
  "max_blocks": 8,
  "blocks": [
    {
      "type": "post",
      "name": "Instagram Post",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Instagram Post Link"
        }
      ]
    }
  ],
    "presets": [
    {
      "name": "BrandPoint Instagram Feed",
      "blocks": [
        {
          "type": "post"
        },
        {
          "type": "post"
        },
        {
          "type": "post"
        },
        {
          "type": "post"
        }
      ]
    }
  ]
}
{% endschema %}
