<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">

  <meta name="theme-color" content="#E03030">
  <link rel="preconnect" href="https://cdn.shopify.com">

  <title>
    {{ page_title }}
    {% if current_tags %}- {{ current_tags | join: ', ' }}{% endif %}
    {% if current_page != 1 %} - Page {{ current_page }}{% endif %}
    {% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}
  </title>

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'animations.css' | asset_url | stylesheet_tag }}
</head>

<body>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="MainContent">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {{ 'app.js' | asset_url | script_tag }}

  <script>
  (function() {
    // 1. फोटो ऑटो-चेंज करने का फंक्शन (जब ग्राहक कलर बटन पर क्लिक करे)
    function handleColorImageSwap(selectedColor) {
      if (!selectedColor) return;
      const cleanColor = selectedColor.toLowerCase().trim();
      const allImages = document.querySelectorAll('img');
      
      allImages.forEach(img => {
        const altText = (img.getAttribute('alt') || '').toLowerCase();
        const srcText = img.src.toLowerCase();
        if (altText.includes(cleanColor) || srcText.includes(cleanColor)) {
          // आपकी थीम की मुख्य प्रोडक्ट इमेजेस के अलग-अलग पॉसिबल सेलेक्टर्स
          const mainImage = document.querySelector('.product__media img, .bp-slide-image img, [data-main-product-image], .shopify-product-form img');
          if (mainImage && img.src !== mainImage.src) {
            mainImage.src = img.src;
            if (mainImage.srcset && img.srcset) mainImage.srcset = img.srcset;
            console.log("Image auto-swapped for color: " + selectedColor);
          }
        }
      });
    }

    // 2. साइज-कलर लॉक करने और कार्ट में सही वैल्यू भेजने का मास्टर फंक्शन
    function lockOptionsAndFixCart() {
      const params = new URLSearchParams(window.location.search);
      const currentVariantId = params.get('variant');
      
      // यह बैकएंड में 'Add to Cart' के हिडन इनपुट्स को सही वेरिएंट आईडी पर लॉक रखेगा
      const hiddenInputs = document.querySelectorAll('input[name="id"]');
      if (currentVariantId && hiddenInputs.length > 0) {
        hiddenInputs.forEach(input => {
          if (input.value !== currentVariantId) {
            input.value = currentVariantId;
          }
        });
      }
    }

    // जब भी कोई साइज या कलर रेडियो बटन/ड्रॉपडाउन बदला जाए
    document.addEventListener('change', function(e) {
      const target = e.target;
      
      // चेक करना कि क्या यूज़र ने कलर बदला है
      if (target.matches('[name*="color" i], [name*="colour" i], .color-input input, [data-color-option]')) {
        handleColorImageSwap(target.value);
      }
      
      setTimeout(lockOptionsAndFixCart, 100);
    });

    // क्लिक डिटेक्शन - अगर बटन रेडियो इनपुट न होकर नॉर्मल लेबल्स (Labels) हैं
    document.addEventListener('click', function(e) {
      const label = e.target.closest('label, button, .variant-input');
      if (label) {
        const text = label.innerText.toLowerCase().trim();
        // अगर क्लिक किए गए बटन में कलर का नाम है
        if (text.includes('white') || text.includes('black') || text.includes('blue') || text.includes('red')) {
          setTimeout(() => handleColorImageSwap(label.innerText), 150);
        }
      }
    });

    // पेज लोड होने पर और ब्राउज़र बैक होने पर वैल्यू लॉक रखना
    window.addEventListener('popstate', lockOptionsAndFixCart);
    document.addEventListener('DOMContentLoaded', lockOptionsAndFixCart);
    
    // सेफ्टी रन: हर आधे सेकंड में बैकएंड ऑटो-चेक होता रहेगा ताकि साइज-कलर रीसेट न हों
    setInterval(lockOptionsAndFixCart, 500);
  })();
  </script>
  </body>
</html>
