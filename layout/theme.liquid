<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">

  <meta name="theme-color" content="#E03030">
  <link rel="preconnect" href="https://cdn.shopify.com">

  <title>
    {{ page_title }}
    {% if current_tags %}- {{ current_tags | join: ', ' }}{% endif %}
    {% if current_page != 1 %} - Page {{ current_page }}{% endif %}
    {% unless page_title contains shop.name %} - {{ shop.name }}{% endunless %}
  </title>

  {{ content_for_header }}

  {{ 'theme.css' | asset_url | stylesheet_tag }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  {{ 'animations.css' | asset_url | stylesheet_tag }}
</head>

<body>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="MainContent">
    {{ content_for_layout }}
  </main>

  {% section 'footer' %}

  {{ 'app.js' | asset_url | script_tag }}

  <!-- Upgrade: Fully Isolated Variant Fix For Custom Home-Page Themes Starts -->
  <script>
  (function() {
    function forceVariantUpdate() {
      const params = new URLSearchParams(window.location.search);
      const currentVariantId = params.get('variant');
      
      // यह आपकी थीम के सभी छिपे हुए इनपुट्स (जैसे XXL, XL) को ढूंढकर फिक्स करेगा
      const hiddenInputs = document.querySelectorAll('input[name="id"]');
      
      if (currentVariantId && hiddenInputs.length > 0) {
        hiddenInputs.forEach(input => {
          input.value = currentVariantId;
        });
        console.log("Custom Theme Fix Active: " + currentVariantId);
      }
    }

    // जब भी कोई साइज (M, L, XXL) या कलर बदला जाए
    window.addEventListener('popstate', forceVariantUpdate);
    document.addEventListener('change', function(e) {
      if (e.target.closest('form') || e.target.matches('[name*="options"], [name="id"], input[type="radio"], select')) {
        setTimeout(forceVariantUpdate, 150);
      }
    });

    // सेफ्टी के लिए हर आधे सेकंड में बैकएंड ऑटो-चेक करता रहेगा
    setInterval(forceVariantUpdate, 500);
  })();
  </script>
  <!-- Upgrade Ends -->

</body>
</html>
